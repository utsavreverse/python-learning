# we can check truth value by bool() function

print(bool([]), bool(None), bool([""]), bool(float('nan')))


#example of using __bool__ method

class Student:
    def __init__(self, marks):
        self.marks = marks

    def __bool__(self):
        return self.marks > 0

marks1 = Student(80)
marks2 = Student(0) #without __bool__ method this object will be true

print(bool(marks1), bool(marks2))


#example of using __len__ method

class Student:
    def __init__(self, name):
        self.name = name

    def __len__(self):
        return len(self.name)

name1 = Student("Bhupendar Jogi")
name2 = Student("")

print(bool(name1), bool(name2))
