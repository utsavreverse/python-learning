"""Direct litral matching"""

def http_error(status):
    match status:
        case 400:
            return "Bad request"
        case 401 | 403 | 404:      #Can add multilple cases with or (|)
            return "Not found"
        case 418:
            return "I'm a teapot"
        case _:
            return "Something's wrong with the internet"

print(http_error(400)) #will go to matching 400 case block
print(http_error(403)) #will go to matching 403 case block
print(http_error(500)) #if nothing matches it will execute the wildcard (case _) and If no wildcard exists, the behavior is a no-op and returns none


"""Pattern case matching"""

# Pattern in each case can takes varibales and arguments
# Point is an (x,y) tuple

def point_matching(x, y):
    point = (x, y)
    match point:
        case (0, 0):
            print("Origin")
        case (0, y):
            print(f"Y={y}")
        case (x, 0):
            print(f"X={x}")
        case (x, y):
            print(f"X={x}, Y={y}")
        case _:
            raise ValueError("Not a point")

point_matching(0, 0) #match both the litrals, goes to first case
point_matching(0, 3) #match first litral and takes value of second argument as y, goes to the second case
point_matching(5, 0) #takes value of first argument as x and matches the second litral, goes to the third case
point_matching(3, 5) #takes value of first argument as x and second argument as y, goes to the fourth case

point_matching(y = 2, x = 3) #although first argument will take it as x, we can always specify values by expilcitly assigning it


class Point:
    __match_args__ = ("x", "y") #used to define that the first argument is x and second is y
    
    def __init__(self, x, y):
        self.x = x
        self.y = y

def where_is(point):
    match point:
        case Point(0, 0): #can't run without __match_args__
            print("Origin")
        case Point(0, y): #can't run without __match_args__
            print(f"Y={y}")
        case Point(x=x, y=0): #can run without __match_args__, because you are explicitly defining x and y using keyword arguments
            print(f"X={x}")
        case Point(x, y) if x==y: #you can add if clause to the pattern, it is known as 'guard', guard will evaluate the conditional..
            print(f"Y=X at {x}")  #..clause, note that value capture happens before the guard is evaluated.
        case Point(): 
            print("Somewhere else")
        case _:
            print("Not a point")

where_is(Point(0, 0))
where_is(Point(0, 3))
where_is(Point(3, 0))
where_is(Point(4, 5))
where_is(Point(5, 5))
where_is("Point")


class Point:
    __match_args__ = ('x', 'y')
    def __init__(self, x, y):
        self.x = x
        self.y = y

#Taking list of Point objects as parameters
def where_is(points):
    match points:
        case []:
            print("No points")
        case [Point(0, 0)]:
            print("The origin")
        case [Point(x, y)]:
            print(f"Single point {x}, {y}")
        case [Point(0, y1), Point(0, y2)]:
            print(f"Two on the Y axis at {y1}, {y2}")
        case _:
            print("Something else")

where_is([])
where_is([Point(0, 0)])
where_is([Point(2, 3)])
where_is([Point(0, 1), Point(0, 2)])
where_is([Point(0, 1), Point(0, 2), Point(0,3)])


# Patterns may use named constants. These must be dotted names to prevent them from being interpreted as capture variable

from enum import Enum
class Color(Enum):
    RED = 'red'
    GREEN = 'green'
    BLUE = 'blue'

color = Color(input("Enter your choice of 'red', 'blue' or 'green': "))

match color:
    case Color.RED:
        print("I see red!")
    case Color.GREEN:
        print("Grass is green")
    case Color.BLUE:
        print("I'm feeling the blues :(")





