"""F-string"""

import datetime

# --- Setup Variables ---
name = "Meow"
age = 9
price = 1234.5678
percent = 0.25
d = datetime.datetime(2025, 1, 27, 15, 30)

# --- 1. Basic Interpolation ---
# Just inserting variables directly
basic = f"Hello, {name}. You are {age} years old."

# --- 2. Expressions & Function Calls ---
# You can run code inside the curly braces
calc = f"Next year, you will be {age + 1}."
func = f"Your name in lowercase is '{name.lower()}'."

# --- 3. Format Specification Mini-Language ---
# Controlling how numbers look (Precision, Commas, Percentages)
formatted_float = f"Price: ${price:.2f}"        # Fixed point: 1234.57
formatted_comma = f"Price: ${price:,.2f}"       # Comma separator: 1,234.57
formatted_pct   = f"Tax: {percent:.1%}"         # Percentage: 25.0%

# --- 4. Alignment and Padding ---
# Structure: {value : fill align width}
# < = Left, > = Right, ^ = Center
align_right  = f"|{name:>10}|"   # Pad with spaces to 10 chars, right align
align_center = f"|{name:^10}|"   # Pad with spaces to 10 chars, center align
pad_zeros    = f"ID: {age:05d}"  # Pad with zeros to 5 digits (00009)
pad_custom   = f"|{name:_<10}|"  # Pad with underscores, left align

# --- 5. Date Formatting ---
# F-strings can interpret datetime objects directly
date_str = f"Meeting is on: {d:%B %d, %Y at %H:%M}"

# --- 6. Debugging (Python 3.8+) ---
# Using '=' prints the variable name AND the value. Very useful for logging.
debug_val = f"{name=}"    # Output: "name='Alice'"
debug_calc = f"{age+5=}"  # Output: "age+5=35"

# --- 7. Escaping Braces ---
# Use double braces {{ }} to show literal curly braces
escaped = f"This is a set: {{1, 2, 3}} and this is a variable: {age}"

# --- Printing Results ---
print(f"1. Basic:       {basic}")
print(f"2. Calculation: {calc}")
print(f"3. Formatting:  {formatted_comma} | {formatted_pct}")
print(f"4. Alignment:   {align_right} | {align_center} | {pad_zeros} | {pad_custom}")
print(f"5. Date:        {date_str}")
print(f"6. Debugging:   {debug_val} | {debug_calc}")
print(f"7. Escaping:    {escaped}")





# --- Setup Variables ---
name = "Meow"
age = 9
point = (3, 9)
user = {"id": 88, "role": "admin"}

# --- 1. Positional Arguments ---
# Arguments are inserted based on their order (0, 1, 2...)
# You can leave brackets empty {} (Python 2.7+) or explicitly use indices {0}
pos_implicit = "{} is {} years old.".format(name, age)
pos_explicit = "{0} is {1} years old. Also {0} loves zoomies.".format(name, age)

# --- 2. Keyword Arguments ---
# More readable; order inside .format() doesn't matter
keyword = "{n} is {a} years old.".format(a=age, n=name)

# --- 3. Accessing Item Attributes/Indices ---
# You can access object attributes or dictionary keys inside the string
# Note: Do NOT use quotes for dict keys inside the {}
coords = "X: {0[0]}, Y: {0[1]}".format(point)
user_info = "User {p[id]} is an {p[role]}".format(p=user)

# --- 4. Unpacking Sequences (*args and **kwargs) ---
# Very useful when your data is already in a list or dictionary
data_list = ["XYZ", 25]
data_dict = {"name": "ABC", "job": "Web developer"}

unpack_list = "Name: {}, Age: {}".format(*data_list)
unpack_dict = "Name: {name}, Job: {job}".format(**data_dict)

# --- 5. Format Specification Mini-Language ---
# Works exactly the same as f-strings
formatted_num = "Price: ${:.2f}".format(1234.5678)
centered      = "|{:<10}|{:^10}|{:>10}|".format("Left", "Center", "Right")

# --- 6. The "Template" Use Case (Why we still use .format) ---
# You can define the structure first, and fill it later (or repeatedly)
log_template = "ERROR: [{code}] - {msg}"

err1 = log_template.format(code=404, msg="Page not found")
err2 = log_template.format(code=500, msg="Internal Server Error")

# --- Printing Results ---
print(f"1. Positional:  {pos_explicit}")
print(f"2. Keyword:     {keyword}")
print(f"3. Accessing:   {coords} | {user_info}")
print(f"4. Unpacking:   {unpack_list} | {unpack_dict}")
print(f"5. Formatting:  {formatted_num}")
print(f"6. Alignment:   {centered}")
print(f"7. Templates:   {err1}")
print(f"                {err2}")





# --- Setup Variables ---
name = "Meow"
age = 9
price = 1234.5678
data = {"item": "Laptop", "cost": 999}

# --- 1. Basic Positional Formatting ---
# Uses type codes: %s (string), %d (integer), %f (float)
# Note: If you have multiple values, you MUST use a tuple (...)
basic = "Hello, %s. You are %d years old." % (name, age)

# --- 2. Floating Point Precision ---
# Control decimal places. The syntax is %.nf
formatted_float = "Price: $%.2f" % price

# --- 3. Padding and Alignment ---
# %10s  -> Right align (pad left with spaces)
# %-10s -> Left align (pad right with spaces)
# %05d  -> Pad number with zeros
align_right = "|%10s|" % "Right"
align_left  = "|%-10s|" % "Left"
pad_zeros   = "ID: %05d" % 42

# --- 4. Named Placeholders (Dictionary) ---
# This is the only way to do "keyword" style arguments with %
# Syntax: %(key)type
dict_fmt = "Item: %(item)s, Cost: $%(cost)d" % data

# --- 5. Different Type Codes ---
# %x = Hexadecimal (lowercase)
# %r = Repr (string representation/debugging)
hex_val  = "The number 255 in hex is: %x" % 255
repr_val = "Debugging string with quotes: %r" % "Hello\nWorld"

# --- 6. The "Gotcha" (Tuple Trap) ---
# If you are printing a SINGLE tuple, you must wrap it in another tuple.
my_tuple = (1, 2)
# bad = "Tuple: %s" % my_tuple  <- This often causes a TypeError
good = "Tuple: %s" % (my_tuple,)

# --- Printing Results ---
print("1. Basic:       %s" % basic)
print("2. Formatting:  %s" % formatted_float)
print("3. Alignment:   %s | %s | %s" % (align_right, align_left, pad_zeros))
print("4. Dictionary:  %s" % dict_fmt)
print("5. Types:       %s | %s" % (hex_val, repr_val))
print("6. Tuple Trap:  %s" % good)


